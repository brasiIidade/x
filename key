local function getRealHWID()
	local tries={
		function() if getdeviceid then return getdeviceid() end end,
		function() if getmacaddress then return getmacaddress() end end,
		function() return game:GetService("RbxAnalyticsService"):GetClientId() end,
	}
	for _,fn in ipairs(tries) do
		local ok,v=pcall(fn)
		if ok and type(v)=="string" and #v>0 then return v end
	end
	return "N/D"
end

