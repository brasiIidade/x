		local col=C.Grey
		if state=="verifying" then col=C.WAIT
		elseif state=="success" then col=C.OK
		elseif state=="error" then col=C.ERR end
		statLbl.Text=msg or ""
		tw(statLbl,{TextColor3=col},.22); tw(statDot,{BackgroundColor3=col},.22)
	end

	verBtn.MouseButton1Click:Connect(function()
		snd(SFX.Click)
		local key=box.Text:gsub("%s+","")
		setStatus("verifying","Verificando chave...")
		vTxt.Text="Verificando..."; verBtn.Active=false
		local result=Junkie.check_key(key)
		verBtn.Active=true; vTxt.Text="Verificar chave"
		if not result then
			setStatus("error","Falha na conexão.")
			snd(SFX.Err); NToast.show(screen,"Erro de conexão","Não foi possível verificar a chave.","error")
			return
		end
		if result.valid then
			saveKey(key); getgenv().SCRIPT_KEY=key
			setStatus("success","Autenticado com sucesso!")
			snd(SFX.Ok); NToast.show(screen,"Autenticado!","Bem-vindo. Carregando...","success")
