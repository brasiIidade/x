local NToast = {queue={}, active=false}
local TOAST_W = MOBILE and 210 or 268
local TOAST_H = 52
local TOAST_GAP = 8
local TOAST_MAX = 4

local function countToasts(screen)
	local n = 0
	for _, c in ipairs(screen:GetChildren()) do
		if c:IsA("Frame") and c:FindFirstChild("_toast") then n = n + 1 end
	end
	return n
end

local function toastNext(screen)
	if #NToast.queue == 0 then return end
	local item = table.remove(NToast.queue, 1)

	local slot = countToasts(screen)

	local isErr = (item.kind == "error")
	local accent = isErr and C.ERR or C.OK
	local icon = isErr and ICONS.Err or ICONS.Ok

	local msgLines = math.ceil(#item.msg / 34)
	local cardH = math.max(TOAST_H, 20 + 16 + msgLines * 14 + 6)
	local targetY = 14 + slot * (cardH + TOAST_GAP)

	local card = mkFrame(screen, {
		Size = UDim2.new(0, TOAST_W, 0, cardH),
		Position = UDim2.new(1, TOAST_W + 30, 0, targetY),
		AnchorPoint = Vector2.new(1, 0),
		BackgroundColor3 = C.Card,
		ZIndex = 200,
	})
	mkCorner(card, 10)
	mkStroke(card, C.Edge, 1)

	local tag = Instance.new("BoolValue")
	tag.Name = "_toast"
	tag.Parent = card

	mkFrame(card, {
		Size = UDim2.new(0, 3, 1, -8),
		Position = UDim2.new(0, 0, 0, 4),
		BackgroundColor3 = accent,
		ZIndex = 201,
	})

	local iw = mkFrame(card, {
		Size = UDim2.new(0, 28, 0, 28),
		Position = UDim2.new(0, 11, 0.5, 0),
		AnchorPoint = Vector2.new(0, 0.5),
		BackgroundColor3 = accent,
		BackgroundTransparency = 0.82,
		ZIndex = 201,
	})
	mkCorner(iw, 14)
	mkImage(iw, {
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.fromScale(.5, .5),
		AnchorPoint = Vector2.new(.5, .5),
		Image = icon,
		ImageColor3 = accent,
		ZIndex = 202,
	})

	mkLabel(card, {
		Size = UDim2.new(1, -52, 0, 16),
		Position = UDim2.new(0, 48, 0, 9),
		Text = item.title,
		TextColor3 = C.White,
		TextSize = 12,
		Font = Enum.Font.GothamBold,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 201,
	})
	mkLabel(card, {
		Size = UDim2.new(1, -54, 0, cardH - 26),
		Position = UDim2.new(0, 48, 0, 27),
		Text = item.msg,
		TextColor3 = C.Grey,
		TextSize = 10,
		Font = Enum.Font.Gotham,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		ZIndex = 201,
	})

	tw(card, {Position = UDim2.new(1, -14, 0, targetY)}, .32, Enum.EasingStyle.Quint)

	task.delay(item.dur or 3.5, function()
		if card.Parent then
			tw(card, {Position = UDim2.new(1, TOAST_W + 40, 0, targetY)}, .25, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
			task.wait(.28)
			pcall(function() card:Destroy() end)
		end
		toastNext(screen)
	end)
end

function NToast.show(screen, title, msg, kind, dur)
	if #NToast.queue >= TOAST_MAX then
		table.remove(NToast.queue, 1)
	end
	table.insert(NToast.queue, {title=title, msg=msg, kind=kind, dur=dur})
	toastNext(screen)
end

