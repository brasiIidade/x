local function tw(o,p,t,s,d)
	TweenSvc:Create(o,TweenInfo.new(t or .28,s or Enum.EasingStyle.Quint,d or Enum.EasingDirection.Out),p):Play()
end
local function mkCorner(p,r)
	local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,r or 6); c.Parent=p; return c
end
local function mkStroke(p,col,th)
	local s=Instance.new("UIStroke"); s.Color=col or C.Edge; s.Thickness=th or 1
	s.Transparency=0; s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border; s.Parent=p; return s
end
local function mkFrame(par,t)
	local f=Instance.new("Frame"); f.BorderSizePixel=0
	for k,v in pairs(t or {}) do f[k]=v end; f.Parent=par; return f
end
local function mkLabel(par,t)
	local l=Instance.new("TextLabel"); l.BorderSizePixel=0; l.BackgroundTransparency=1
	for k,v in pairs(t or {}) do l[k]=v end; l.Parent=par; return l
end
local function mkImage(par,t)
	local i=Instance.new("ImageLabel"); i.BorderSizePixel=0; i.BackgroundTransparency=1
	for k,v in pairs(t or {}) do i[k]=v end; i.Parent=par; return i
end
local function mkBtn(par,t)
	local b=Instance.new("TextButton"); b.BorderSizePixel=0; b.AutoButtonColor=false; b.Text=""
