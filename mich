local function lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local FPS_HIGH  = Color3.fromRGB(60,  120,  90)
local FPS_MID   = Color3.fromRGB(80,   60, 110)
local FPS_LOW   = Color3.fromRGB(110,  35,  50)

local PING_LOW  = Color3.fromRGB(40,   90,  85)
local PING_MID  = Color3.fromRGB(70,   50, 100)
local PING_HIGH = Color3.fromRGB(100,  30,  45)

local function fpsColor(fps)
    if fps >= 60 then
        return FPS_HIGH
    elseif fps >= 45 then
        return lerpColor(FPS_HIGH, FPS_MID, (60 - fps) / 15)
    elseif fps >= 25 then
        return lerpColor(FPS_MID, FPS_LOW, (45 - fps) / 20)
    else
        return FPS_LOW
    end
end

local function pingColor(ping)
    if ping <= 60 then
        return PING_LOW
    elseif ping <= 120 then
        return lerpColor(PING_LOW, PING_MID, (ping - 60) / 60)
    elseif ping <= 250 then
        return lerpColor(PING_MID, PING_HIGH, (ping - 120) / 130)
    else
        return PING_HIGH
    end
end

local DISCORD_PALETTE = {
    Color3.fromRGB(255, 255, 255),
    Color3.fromRGB(200, 210, 255),
    Color3.fromRGB(180, 190, 255),
    Color3.fromRGB(160, 180, 255),
    Color3.fromRGB(190, 200, 255),
    Color3.fromRGB(220, 225, 255),
    Color3.fromRGB(255, 255, 255),
}

local CYCLE_DURATION = 5

local function discordColor(t)
    local count  = #DISCORD_PALETTE - 1
    local scaled = t * count
    local idx    = math.clamp(math.floor(scaled) + 1, 1, count)
    local frac   = scaled - math.floor(scaled)
    return lerpColor(DISCORD_PALETTE[idx], DISCORD_PALETTE[idx + 1], frac)
end

local function colorToHex(c)
    return string.format("#%02X%02X%02X",
        math.floor(c.R * 255),
        math.floor(c.G * 255),
        math.floor(c.B * 255)
    )
end

