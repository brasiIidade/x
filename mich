local CanBeEnabled = {"ParticleEmitter", "Trail", "Smoke", "Fire", "Sparkles"}
local conexaoAntilag = nil

local function CheckIfBad(Inst)
    if not Inst:IsDescendantOf(Players)
    and not (function()
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and Inst:IsDescendantOf(v.Character) then return true end
        end
    end)()
    and (LocalPlayer.Character and not Inst:IsDescendantOf(LocalPlayer.Character)) then
        if Inst:IsA("SpecialMesh") then Inst.MeshId = "" Inst.TextureId = ""
        elseif Inst:IsA("FaceInstance") then Inst.Transparency = 1 Inst.Shiny = 1
        elseif Inst:IsA("ShirtGraphic") then Inst.Graphic = ""
        elseif table.find(CanBeEnabled, Inst.ClassName) then Inst.Enabled = false
        elseif Inst:IsA("PostEffect") then Inst.Enabled = false
        elseif Inst:IsA("Explosion") then Inst.BlastPressure = 1 Inst.BlastRadius = 1 Inst.Visible = false
        elseif Inst:IsA("Clothing") or Inst:IsA("SurfaceAppearance") or Inst:IsA("BaseWrap") then Inst:Destroy()
        elseif Inst:IsA("BasePart") and not Inst:IsA("MeshPart") then Inst.Material = Enum.Material.Plastic Inst.Reflectance = 0
        elseif Inst:IsA("Model") then Inst.LevelOfDetail = 1
        elseif Inst:IsA("MeshPart") then Inst.RenderFidelity = 2 Inst.Reflectance = 0 Inst.Material = Enum.Material.Plastic
        end
    end
end

