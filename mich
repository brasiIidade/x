    local d = { PlaceId = game.PlaceId, Parts = {} }
    for p, sz in pairs(f3x.ModifiedParts) do
        if p and p.Parent then
            d.Parts[#d.Parts + 1] = { Path = p:GetFullName(), CFrame = { p.CFrame:GetComponents() }, Size = { sz.X, sz.Y, sz.Z } }
        end
    end
    writefile(f3x_fDir .. "/" .. n .. ".json", HttpService:JSONEncode(d))
    return f3x.ListConfigs()
end

local unp = table.unpack or unpack

local function getObj(path)
    -- GetFullName() retorna "game.Workspace.Parte" ou "Game.Workspace.Parte"
    -- percorre cada segmento ignorando o primeiro se for "game"/"Game"
    local parts = {}
    for s in path:gmatch("[^%.]+") do parts[#parts + 1] = s end
    local cur = game
    local start = (parts[1] and parts[1]:lower() == "game") and 2 or 1
    for i = start, #parts do
        local child = cur:FindFirstChild(parts[i])
        if not child then return nil end
        cur = child
    end
    return cur
end

f3x.ApplyConfig = function(n)
    if not n then return false end
    local p = f3x_fDir .. "/" .. n .. ".json"
    if not isfile(p) then return false end
    local d
    pcall(function() d = HttpService:JSONDecode(readfile(p)) end)
    if not d then return false end
    if d.PlaceId ~= game.PlaceId then
        notificar("F3X de outro mapa", 3, "lucide:alert-circle")
        return false
    end

    local fallbackByName = {}
    for _, o in ipairs(game:GetService("Workspace"):GetDescendants()) do
        if o:IsA("BasePart") then
            local bucket = fallbackByName[o.Name]
            if not bucket then bucket = {}; fallbackByName[o.Name] = bucket end
            bucket[#bucket + 1] = o
        end
    end

    for _, v in ipairs(d.Parts or {}) do
        local targetCf = CFrame.new(unp(v.CFrame))
        local sz       = Vector3.new(unp(v.Size))
        local foundPart = nil

        -- 1) tenta pelo path exato
        local obj = getObj(v.Path)
        if obj and obj:IsA("BasePart") and (obj.Position - targetCf.Position).Magnitude < 2 then
            foundPart = obj
        end

        -- 2) fallback: usa o lookup já construído, busca só pelo último segmento do path
        if not foundPart then
            local partName = v.Path:match("([^%.]+)$")
            local bucket   = fallbackByName[partName]
            if bucket then
                for _, o in ipairs(bucket) do
                    if (o.Position - targetCf.Position).Magnitude < 2 then
                        foundPart = o; break
                    end
                end
            end
        end

        if foundPart then
            foundPart.Size = sz
            f3x.ModifiedParts[foundPart] = sz
        end
    end
    return true
end

f3x.DeleteConfig = function(n)
    if not n then notificar("F3X: Nenhuma seleção", 3, "lucide:alert-circle"); return nil end
    delfile(f3x_fDir .. "/" .. n .. ".json")
    return f3x.ListConfigs()
end

