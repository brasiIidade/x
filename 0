local function criarsection(title, icon, opened)
    return main:Section({
    Title = title,
    Icon = icon,
    Opened = opened or false
})
end

local function criartab(title, icon, locked)
    return main:Tab({
        Title = title,
        Icon = icon,
        Locked = locked or false
    })
end

