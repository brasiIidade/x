    local function UpdateStatus(status, msg)
        local color = Config.Colors.TextSec
        local dotColor = Color3.fromRGB(80, 80, 80)

        if status == "verify" then
            color = Color3.fromRGB(255, 200, 50)
            dotColor = color
        elseif status == "success" then
            color = Config.Colors.Primary
            dotColor = color
        elseif status == "error" then
            color = Config.Colors.Error
            dotColor = color
        end

        Utils.Tween(StatusText, {TextColor3 = color}, 0.3)
        Utils.Tween(StatusDot, {BackgroundColor3 = dotColor}, 0.3)
        StatusText.Text = msg
    end

    local function CloseUI()
