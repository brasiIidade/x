        local key = box.Text:gsub("%s+", "")
        SetStatus("verifying")
        redeemText.Text = "Verificando..."
        redeem.Active = false
        
        local result = Junkie.check_key(key)
        
        redeem.Active = true
        redeemText.Text = ConfigData.Texts.BtnVerify
        
        if not result then
            SetStatus("error")
            PlayAudio(ConfigData.Sounds.Error)
            ToastSystem.Create(screen, ConfigData.Texts.ToastError, "error")
            return
        end
        
        if result.valid then
            saveVerifiedKey(key)
            getgenv().SCRIPT_KEY = key
            SetStatus("success")
            PlayAudio(ConfigData.Sounds.Success)
            ToastSystem.Create(screen, ConfigData.Texts.ToastSuccess, "success")
            task.wait(0.8)
            CloseMenu()
        else
            SetStatus("error")
            PlayAudio(ConfigData.Sounds.Error)
            ToastSystem.Create(screen, result.message or ConfigData.Texts.ToastInvalid, "error")
        end
    end)
    
    getKey.MouseButton1Click:Connect(function()
        PlayAudio(ConfigData.Sounds.Click)
        setclipboard(Junkie.get_key_link())
        ToastSystem.Create(screen, ConfigData.Texts.ToastCopied, "success")
    end)
    
    SetBlur(true)
    Utils.Tween(main, {Position = UDim2.new(0.5, 0, 0.5, 0), BackgroundTransparency = 0}, Configuration.Animations.Intro, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
    Utils.Tween(mainStroke, {Transparency = 0}, Configuration.Animations.Intro)

    task.wait(0.1)

    for _, v in pairs(main:GetDescendants()) do
        if v:IsA("GuiObject") and v.Name ~= "MainContainer" then
            if v.Name == "CloseBtn" then
                 Utils.Tween(v, {TextTransparency = 0}, 0.5)
            elseif v:IsA("Frame") then
                local shouldBeVisible = (v == logoContainer or v == statusCard or v == inputFrame or v == sIndicator or v == redeem)
                Utils.Tween(v, {BackgroundTransparency = shouldBeVisible and 0 or 1}, 0.5)
            elseif v:IsA("TextLabel") or v:IsA("TextBox") then
                Utils.Tween(v, {TextTransparency = 0}, 0.5)
            elseif v:IsA("ImageLabel") then
                Utils.Tween(v, {ImageTransparency = 0}, 0.5)
            elseif v:IsA("UIStroke") then
                 Utils.Tween(v, {Transparency = 0}, 0.5)
            end
        end
    end
    
    return screen
end

local savedKey = loadVerifiedKey()
local keyToCheck = savedKey
if not keyToCheck then
    keyToCheck = getgenv().SCRIPT_KEY
end

local result = Junkie.check_key(keyToCheck)
if result and result.valid then
    if result.message == "KEYLESS" then
        getgenv().SCRIPT_KEY = "KEYLESS"
    elseif result.message == "KEY_VALID" then
        if not savedKey and keyToCheck then
            saveVerifiedKey(keyToCheck)
        end
        getgenv().SCRIPT_KEY = keyToCheck
    else
        Build()
    end
else
    Build()
end

while not getgenv().SCRIPT_KEY do
    task.wait(0.1)
end
