    local NotifyFrame = Instance.new("Frame")
    NotifyFrame.Size = UDim2.new(1, 0, 0, 0)
    NotifyFrame.Position = UDim2.new(0, 0, 1, 0)
    NotifyFrame.BackgroundColor3 = Config.Colors.Accent
    NotifyFrame.BorderSizePixel = 0
    NotifyFrame.Parent = Main

    local NotifyLabel = Instance.new("TextLabel")
    NotifyLabel.Size = UDim2.fromScale(1, 1)
    NotifyLabel.BackgroundTransparency = 1
    NotifyLabel.TextColor3 = Config.Colors.Background
    NotifyLabel.Font = Enum.Font.GothamBold
    NotifyLabel.TextSize = 12
    NotifyLabel.Text = ""
    NotifyLabel.Parent = NotifyFrame

    local function AnimateIn()
        TweenService:Create(Blur, TweenInfo.new(1), {Size = 20}):Play()
        TweenService:Create(Main, TweenInfo.new(0.6, Enum.EasingStyle.Back), {BackgroundTransparency = 0}):Play()
        TweenService:Create(MainStroke, TweenInfo.new(0.6), {Transparency = 0}):Play()
        task.wait(0.2)
        for _, v in pairs(Main:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
                TweenService:Create(v, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
            elseif v == InputBg or v == VerifyBtn then
                TweenService:Create(v, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
            elseif v:IsA("UIStroke") then
                TweenService:Create(v, TweenInfo.new(0.5), {Transparency = 0}):Play()
            end
        end
    end

    local function CloseApp()
        TweenService:Create(Blur, TweenInfo.new(0.5), {Size = 0}):Play()
        TweenService:Create(Main, TweenInfo.new(0.4), {Position = UDim2.fromScale(0.5, 0.6), BackgroundTransparency = 1}):Play()
        for _, v in pairs(Main:GetDescendants()) do
            if v:IsA("GuiObject") then
                TweenService:Create(v, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
                if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
                    TweenService:Create(v, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
                end
                if v:IsA("UIStroke") then
                    TweenService:Create(v, TweenInfo.new(0.3), {Transparency = 1}):Play()
                end
            end
        end
        task.wait(0.5)
        Blur:Destroy()
        Screen:Destroy()
    end

    local function Notify(msg, isError)
        NotifyLabel.Text = msg
        NotifyFrame.BackgroundColor3 = isError and Config.Colors.Error or Config.Colors.Accent
        TweenService:Create(NotifyFrame, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 0, 25), Position = UDim2.new(0, 0, 1, -25)}):Play()
        task.delay(2, function()
            TweenService:Create(NotifyFrame, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 1, 0)}):Play()
        end)
    end

    local function Shake()
        local x = Main.Position.X.Scale
        local y = Main.Position.Y.Scale
        local offset = 5
        for i = 1, 5 do
            Main.Position = UDim2.new(x, math.random(-offset, offset), y, math.random(-offset, offset))
            task.wait(0.03)
        end
        Main.Position = UDim2.fromScale(x, y)
    end

    local dragging, dragInput, dragStart, startPos
    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    Main.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    InputBox.Focused:Connect(function()
        TweenService:Create(InputStroke, TweenInfo.new(0.3), {Color = Config.Colors.Accent}):Play()
    end)
    InputBox.FocusLost:Connect(function()
        TweenService:Create(InputStroke, TweenInfo.new(0.3), {Color = Config.Colors.Border}):Play()
    end)

    CloseBtn.MouseButton1Click:Connect(function()
        playSound(Config.Assets.SoundClick)
        CloseApp()
    end)

    GetKeyBtn.MouseButton1Click:Connect(function()
        playSound(Config.Assets.SoundClick)
        setclipboard(Junkie.get_key_link())
        Notify(Config.Text.NotifyCopied, false)
    end)

    VerifyBtn.MouseButton1Click:Connect(function()
        local k = InputBox.Text:gsub("%s+", "")
        if k == "" then
            playSound(Config.Assets.SoundError)
            Shake()
            Notify(Config.Text.NotifyEmpty, true)
            return
        end

        playSound(Config.Assets.SoundClick)
        VerifyBtn.Text = "..."
        StatusText.Text = Config.Text.StatusVerifying
        StatusText.TextColor3 = Config.Colors.Accent

        local res = Junkie.check_key(k)

        if res and res.valid then
            playSound(Config.Assets.SoundSuccess)
            saveVerifiedKey(k)
            getgenv().SCRIPT_KEY = k
            StatusText.Text = Config.Text.StatusSuccess
            Notify(Config.Text.StatusSuccess, false)
            task.wait(1)
            CloseApp()
        else
            playSound(Config.Assets.SoundError)
            Shake()
            VerifyBtn.Text = Config.Text.ButtonVerify
            StatusText.Text = res and res.message or Config.Text.StatusError
            StatusText.TextColor3 = Config.Colors.Error
            Notify(res and res.message or Config.Text.NotifyError, true)
        end
    end)

    AnimateIn()
end

local saved = loadVerifiedKey()
if saved then
    local res = Junkie.check_key(saved)
    if res and res.valid then
        getgenv().SCRIPT_KEY = saved
    else
        CreateUI()
    end
else
    CreateUI()
end

while not getgenv().SCRIPT_KEY do
    task.wait(0.1)
end
