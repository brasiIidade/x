local Utils = {}

Utils.Tween = function(obj, props, time, style, dir)
    local t = TweenService:Create(obj, TweenInfo.new(time or 0.3, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out), props)
    t:Play()
    return t
end

Utils.Round = function(obj, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 12)
    c.Parent = obj
    return c
end

Utils.CreateStroke = function(parent, color, thickness, transparency)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Configuration.Colors.Border
    stroke.Thickness = thickness or 1
    stroke.Transparency = transparency or 0
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = parent
    return stroke
end

-- [[ FUNÇÃO DRAGABLE ]] --
Utils.MakeDraggable = function(gui)
    local dragging
    local dragInput
    local dragStart
    local startPos

    local function update(input)
        local delta = input.Position - dragStart
        Utils.Tween(gui, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.1)
    end

    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = gui.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    gui.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

local function SetBlur(enabled)
    local blur = Lighting:FindFirstChild("JunkieBlurEnhanced")
    if enabled then
        if not blur then
            blur = Instance.new("BlurEffect")
            blur.Name = "JunkieBlurEnhanced"
            blur.Size = 0
            blur.Parent = Lighting
        end
        Utils.Tween(blur, {Size = 15}, Configuration.Animations.Intro, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
    elseif blur then
        Utils.Tween(blur, {Size = 0}, Configuration.Animations.Outro, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        task.delay(Configuration.Animations.Outro + 0.1, function() if blur then blur:Destroy() end end)
    end
end

-- SISTEMA DE NOTIFICAÇÃO
local ToastSystem = {ActiveToasts = {}, MaxToasts = 3, ToastSpacing = 10}

ToastSystem.Create = function(parent, message, toastType, duration)
    if #ToastSystem.ActiveToasts >= ToastSystem.MaxToasts then
        local oldest = table.remove(ToastSystem.ActiveToasts, 1)
        if oldest and oldest.Parent then oldest:Destroy() end
    end
    
    local isError = toastType == "error"
    local iconId = isError and Icons.ToastError or Icons.ToastSuccess
    local accentColor = isError and Configuration.Colors.StatusError or Configuration.Colors.StatusSuccess

    local toast = Instance.new("Frame")
    toast.Name = tick()
    toast.Size = UDim2.new(0, 0, 0, 45) -- Menor
    toast.Position = UDim2.new(0.5, 0, 0, 40)
    toast.AnchorPoint = Vector2.new(0.5, 0)
    toast.BackgroundColor3 = Configuration.Colors.Surface
    toast.ZIndex = 300
    toast.ClipsDescendants = true
    toast.Parent = parent
    Utils.Round(toast, 8)
    Utils.CreateStroke(toast, Configuration.Colors.Border, 1, 0)
    
    local iconContainer = Instance.new("Frame")
    iconContainer.Size = UDim2.new(0, 45, 1, 0)
    iconContainer.BackgroundColor3 = Color3.new(0,0,0)
    iconContainer.BackgroundTransparency = 0.8
    iconContainer.Parent = toast
    
    local iconImg = Instance.new("ImageLabel")
    iconImg.Size = UDim2.fromOffset(20, 20)
    iconImg.AnchorPoint = Vector2.new(0.5, 0.5)
    iconImg.Position = UDim2.fromScale(0.5, 0.5)
    iconImg.BackgroundTransparency = 1
    iconImg.Image = iconId
    iconImg.ImageColor3 = accentColor
    iconImg.Parent = iconContainer

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, -55, 1, 0)
    text.Position = UDim2.new(0, 55, 0, 0)
    text.BackgroundTransparency = 1
    text.Text = tostring(message)
    text.TextColor3 = Configuration.Colors.TextMain
    text.TextSize = 12
    text.Font = Enum.Font.GothamMedium
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.TextYAlignment = Enum.TextYAlignment.Center
    text.TextWrapped = true
    text.ZIndex = 302
    text.Parent = toast

    table.insert(ToastSystem.ActiveToasts, toast)
    ToastSystem.RepositionToasts()
    
    local width = isMobile() and 260 or 280
    Utils.Tween(toast, {Size = UDim2.new(0, width, 0, 45)}, Configuration.Animations.Medium, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    
    task.delay(duration or 3.5, function()
        if toast.Parent then
            Utils.Tween(toast, {Position = UDim2.new(0.5, 0, 0, -60), BackgroundTransparency = 1}, Configuration.Animations.Medium)
            if text then Utils.Tween(text, {TextTransparency = 1}, Configuration.Animations.Medium) end
            if iconImg then Utils.Tween(iconImg, {ImageTransparency = 1}, Configuration.Animations.Medium) end
            if toast:FindFirstChild("UIStroke") then Utils.Tween(toast.UIStroke, {Transparency = 1}, Configuration.Animations.Medium) end
            
            for i, t in ipairs(ToastSystem.ActiveToasts) do
                if t == toast then table.remove(ToastSystem.ActiveToasts, i) break end
            end
            task.wait(Configuration.Animations.Medium)
            toast:Destroy()
            ToastSystem.RepositionToasts()
        end
    end)
end

ToastSystem.RepositionToasts = function()
    for i, toast in ipairs(ToastSystem.ActiveToasts) do
        local targetY = 40 + ((i - 1) * (45 + ToastSystem.ToastSpacing))
        Utils.Tween(toast, {Position = UDim2.new(0.5, 0, 0, targetY)}, Configuration.Animations.Medium)
    end
end

