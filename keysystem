local function hasFileSystemSupport()
    return (writefile and readfile and isfile and delfile)
end

local function saveVerifiedKey(key)
    if not hasFileSystemSupport() then return end
    pcall(writefile, "michigun.key.txt", key)
end

local function loadVerifiedKey()
    if not hasFileSystemSupport() then return nil end
    local s, r = pcall(readfile, "michigun.key.txt")
    if s then return r end
    return nil
end

local function playSound(id)
    local s = Instance.new("Sound")
    s.SoundId = id
    s.Volume = 1
    s.Parent = game:GetService("SoundService")
    s.PlayOnRemove = true
    s:Destroy()
end

