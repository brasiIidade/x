local function GetProtectionParent()
    if gethui then
        return gethui()
    elseif syn and syn.protect_gui then
        return syn.protect_gui
    else
        return CoreGui
    end
end

local function hasFileSystem()
    return (writefile and readfile and isfile and delfile)
end

local function saveKey(key)
    if hasFileSystem() then pcall(writefile, "michigun.key.txt", key) end
end

local function loadKey()
    if hasFileSystem() and pcall(isfile, "michigun.key.txt") and isfile("michigun.key.txt") then
        return readfile("michigun.key.txt")
    end
    return nil
end

local function deleteKey()
    if hasFileSystem() and pcall(isfile, "michigun.key.txt") then
        pcall(delfile, "michigun.key.txt")
    end
end

local Utils = {}

function Utils.Tween(obj, props, time, style, dir)
    local info = TweenInfo.new(time or 0.3, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out)
    local tween = TweenService:Create(obj, info, props)
    tween:Play()
    return tween
end

function Utils.Round(obj, radius)
    local c = Instance.new("UICorner")
    c.Name = GetRandomName()
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = obj
    return c
end

function Utils.Stroke(obj, color, thick)
    local s = Instance.new("UIStroke")
    s.Name = GetRandomName()
    s.Color = color or Color3.fromRGB(40,40,40)
    s.Thickness = thick or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = obj
    return s
end

function Utils.PlaySound(id)
    local sound = Instance.new("Sound")
    sound.Name = GetRandomName()
    sound.SoundId = id
    sound.Volume = 1
    sound.Parent = game:GetService("SoundService")
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 3)
end

local function ToggleBlur(enabled)
    local blurName = "JunkieBlur_" .. string.sub(LocalPlayer.UserId, 1, 4)
    local blur = Lighting:FindFirstChild(blurName)
    if enabled then
        if not blur then
            blur = Instance.new("BlurEffect")
            blur.Name = blurName
            blur.Size = 0
            blur.Parent = Lighting
        end
        Utils.Tween(blur, {Size = 24}, 0.8)
    else
        if blur then
            Utils.Tween(blur, {Size = 0}, 0.5)
            game:GetService("Debris"):AddItem(blur, 0.6)
        end
    end
end

