        Utils.Tween(Main, {Position = UDim2.new(0.5, 0, 0.5, 80), BackgroundTransparency = 1}, 0.5)
        
        for _, v in pairs(Main:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
                Utils.Tween(v, {TextTransparency = 1}, 0.3)
            elseif v:IsA("Frame") or v:IsA("ImageLabel") then
                Utils.Tween(v, {BackgroundTransparency = 1, ImageTransparency = 1}, 0.3)
            elseif v:IsA("UIStroke") then
                Utils.Tween(v, {Transparency = 1}, 0.3)
            end
        end
        
        task.wait(0.6)
        Screen:Destroy()
    end

    local function VerifyKey()
        local key = InputBox.Text:gsub("%s+", "")
        if key == "" then
            ShakeWindow()
            ShowNotification(Config.Texts.NotifyEmpty, Config.Colors.Error)
            return
        end

        UpdateStatus("verify", Config.Texts.StatusVerifying)
        
        local result = Junkie.check_key(key)
        
        if result and result.valid then
            Utils.PlaySound(Config.Sounds.Success)
            UpdateStatus("success", Config.Texts.StatusSuccess)
            saveKey(key)
            getgenv().SCRIPT_KEY = key
            ShowNotification(Config.Texts.StatusSuccess, Config.Colors.Primary)
            task.wait(1)
            CloseUI()
        else
            Utils.PlaySound(Config.Sounds.Error)
            ShakeWindow()
            UpdateStatus("error", result.message or Config.Texts.StatusError)
            ShowNotification(Config.Texts.StatusError, Config.Colors.Error)
        end
    end

