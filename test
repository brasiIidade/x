local function GetSortedThemes()
    local list = {}
    for name, _ in pairs(UI:GetThemes()) do
        table.insert(list, {
            Title = name,
            Desc = cor({"Aplicar tema "}, {name, "#00AAFF"}),
            Icon = "lucide:paint-bucket"
        })
    end
    table.sort(list, function(a, b) return a.Title < b.Title end)
    return list
end

