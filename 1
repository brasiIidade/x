    Title = "Noclip",
    Desc = "Permite atravessar paredes",
    Callback = function(state)
        if _G.PlayerMod and _G.PlayerMod.ToggleNoclip then
            _G.PlayerMod.ToggleNoclip(state)
            if state then
                notificar("Ativado", 2, "lucide:ghost")
            else
                notificar("Desativado", 2, "lucide:ban")
            end
        end
    end
})

Player:Space()

Player:Toggle({
    Title = "Habilitar chat",
    Desc = "Permite você ver o histórico de mensagens no chat",
    Callback = function(v)
        if _G.PlayerMod and _G.PlayerMod.ToggleChat then
            _G.PlayerMod.ToggleChat(v)
        end
    end
})

Player:Space()

local TargetName = ""

Player:Input({
    Title = "Jogador",
    Desc = "Digite o nome do jogador",
    Placeholder = "Nome",
    Callback = function(text)
        TargetName = text
    end
})

Player:Toggle({
    Title = "Espectar jogador",
    Desc = "Especta o jogador",
    Callback = function(v)
        if _G.PlayerMod and _G.PlayerMod.ToggleView then
            local result = _G.PlayerMod.ToggleView(v, TargetName)
            if v then
                if result then
                    notificar("Espectando: " .. result, 3, "lucide:eye")
                else
                    notificar("Jogador não encontrado", 2, "lucide:search-x")
                end
            end
        end
    end
})

Player:Button({
    Title = "Teleportar",
    Desc = "Teleporta ao jogador",
    Callback = function()
        if _G.PlayerMod and _G.PlayerMod.TeleportTo then
            local result = _G.PlayerMod.TeleportTo(TargetName)
            if result then
                notificar("Teleportado para: " .. result, 3, "lucide:plane")
            else
                notificar("Jogador não encontrado", 2, "lucide:search-x")
            end
        end
    end
})

Player:Button({
    Title = "Voltar",
    Desc = "Retorna para a última posição antes do teleport",
    Callback = function()
        if _G.PlayerMod and _G.PlayerMod.ReturnPos then
            if _G.PlayerMod.ReturnPos() then
                notificar("Retornado", 2, "lucide:undo-2")
            else
                notificar("Nenhuma posição salva", 2, "lucide:x")
            end
        end
    end
})

task.spawn(function()
    repeat task.wait(0.5) until _G.PlayerMod and _G.PlayerMod.IsReady
end)



-- configurações
local GerenciadorConfig = main.ConfigManager
local NomeConfig = ""
local ConfigSelecionada = nil
local DropdownListaConfig = nil

local function AtualizarListaConfig()
    local configs = GerenciadorConfig:AllConfigs()
    if DropdownListaConfig then
        DropdownListaConfig:Refresh(configs)
    end
end

Configs:Input({
    Title = "Nome da configuração",
    Desc = "Dê um nome para a configuração",
    Value = "",
    Placeholder = "Digite aqui...",
    InputIcon = "lucide:type",
    Type = "Input",
    Callback = function(texto)
        NomeConfig = texto
    end
})

Configs:Button({
    Title = "Criar configuração",
    Desc = "Salva a configuração atual",
    Icon = "lucide:plus",
    Callback = function()
        if NomeConfig ~= "" then
            local cfg = GerenciadorConfig:CreateConfig(NomeConfig)
            cfg:Save()
            notificar("Salvo como " .. NomeConfig, 3, "lucide:check")
            AtualizarListaConfig()
        else
            notificar("Digite um nome válido", 3, "lucide:x")
        end
    end
})

Configs:Section({ 
    Title = "Gerenciamento", 
    Icon = "lucide:list" 
})

DropdownListaConfig = Configs:Dropdown({
    Title = "Configurações salvas",
    Desc = "Selecione uma configuração",
    Values = GerenciadorConfig:AllConfigs(),
    Value = "Nenhuma",
    Callback = function(val)
        ConfigSelecionada = val
    end
})

Configs:Button({
    Title = "Carregar",
    Desc = "Carrega a configuração",
    Icon = "lucide:upload",
    Callback = function()
        if ConfigSelecionada then
            local cfg = GerenciadorConfig:CreateConfig(ConfigSelecionada)
            cfg:Load()
            notificar("Carregado: " .. ConfigSelecionada, 3, "lucide:check")
        else
            notificar("Nenhuma configuração selecionada", 3, "lucide:x")
        end
    end
})

Configs:Button({
    Title = "Sobrescrever",
    Desc = "Salva na configuração atual",
    Icon = "lucide:save",
    Callback = function()
        if ConfigSelecionada then
            local cfg = GerenciadorConfig:CreateConfig(ConfigSelecionada)
            cfg:Save()
            notificar("Alterado: " .. ConfigSelecionada, 3, "lucide:check")
        else
            notificar("Nenhuma configuração selecionada", 3, "lucide:x")
        end
    end
})

Configs:Button({
    Title = "Deletar",
    Desc = "Apaga a configuração",
    Icon = "lucide:trash",
    Callback = function()
        if ConfigSelecionada then
            local cfg = GerenciadorConfig:CreateConfig(ConfigSelecionada)
            cfg:Delete()
            notificar("Deletado: " .. ConfigSelecionada, 3, "lucide:trash")
            AtualizarListaConfig()
        else
            notificar("Nenhuma configuração selecionada", 3, "lucide:x")
        end
    end
})

Configs:Button({
    Title = "Atualizar lista",
    Desc = "Recarrega as configurações",
    Icon = "lucide:refresh-cw",
    Callback = function()
        AtualizarListaConfig()
    end
})
