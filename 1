-- configs
local ConfigManager = main.ConfigManager
local ConfigName = ""
local SelectedConfig = nil
local ConfigListDropdown = nil

local function UpdateConfigList()
    local configs = ConfigManager:AllConfigs()
    if ConfigListDropdown then
        ConfigListDropdown:Refresh(configs)
    end
end

Configs:Input({
    Title = "Nome da Configuração",
    Desc = "Digite o nome para criar",
    Placeholder = "Nome...",
    InputIcon = "lucide:type",
    Callback = function(text)
        ConfigName = text
    end
})

Configs:Button({
    Title = "Criar Config",
    Desc = "Salva com o nome digitado acima",
    Callback = function()
        if ConfigName ~= "" then
            local cfg = ConfigManager:CreateConfig(ConfigName)
            cfg:Save()
            notificar("Config", "Salvo como " .. ConfigName, 3, "lucide:check")
            UpdateConfigList()
        else
            notificar("Erro", "Digite um nome válido", 3, "lucide:x")
        end
    end
})

Configs:Space()

ConfigListDropdown = Configs:Dropdown({
    Title = "Arquivos Salvos",
    Desc = "Selecione uma configuração",
    Values = ConfigManager:AllConfigs(),
    Value = nil,
    Multi = false,
    AllowNone = true,
    Callback = function(val)
        SelectedConfig = val
    end
})

Configs:Button({
    Title = "Carregar",
    Desc = "Carrega a config selecionada",
    Callback = function()
        if SelectedConfig then
            local cfg = ConfigManager:CreateConfig(SelectedConfig)
            cfg:Load()
            notificar("Config", "Carregado: " .. SelectedConfig, 3, "lucide:check")
        else
            notificar("Erro", "Nenhuma config selecionada", 3, "lucide:x")
        end
    end
})

Configs:Button({
    Title = "Sobrescrever",
    Desc = "Salva por cima da selecionada",
    Callback = function()
        if SelectedConfig then
            local cfg = ConfigManager:CreateConfig(SelectedConfig)
            cfg:Save()
            notificar("Config", "Sobrescrito: " .. SelectedConfig, 3, "lucide:check")
        else
            notificar("Erro", "Nenhuma config selecionada", 3, "lucide:x")
        end
    end
})

Configs:Button({
    Title = "Deletar",
    Desc = "Apaga o arquivo permanentemente",
    Callback = function()
        if SelectedConfig then
            local cfg = ConfigManager:CreateConfig(SelectedConfig)
            cfg:Delete()
            notificar("Config", "Deletado: " .. SelectedConfig, 3, "lucide:trash")
            if ConfigListDropdown then ConfigListDropdown:Select(nil) end
            UpdateConfigList()
        else
            notificar("Erro", "Nenhuma config selecionada", 3, "lucide:x")
        end
    end
})

Configs:Button({
    Title = "Atualizar Lista",
    Desc = "Recarrega os arquivos da pasta",
    Callback = function()
        UpdateConfigList()
    end
})
