local function PL_resolveUserId(input)
    local id = tonumber(input)
    local name
    local ok = pcall(function()
        if id then
            name = Players:GetNameFromUserIdAsync(id)
        else
            id   = Players:GetUserIdFromNameAsync(input)
            name = Players:GetNameFromUserIdAsync(id)
        end
    end)
    if ok and id then return id, name end
    return nil, nil
end

