    for p, sz in pairs(s) do r[p] = p.Size; p.Size = sz; f3x.ModifiedParts[p] = sz end
    table.insert(f3x.RedoStack, r)
    if f3x.UpdateUI then task.defer(f3x.UpdateUI) end
end

f3x.Redo = function()
