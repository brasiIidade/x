        ES:Button({ Title = "Money", Desc = cor({ "Pega", "#00FF00" }, { " o dinheiro" }), Icon = "lucide:gem", Callback = function() if getgenv().DeltaLogic and getgenv().DeltaLogic.GetRich then getgenv().DeltaLogic.GetRich() end end })

