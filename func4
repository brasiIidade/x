        highlight = hl,
        billboard = bb,
        labels    = {
            name   = espMakeLabel(bb, 1, Color3.new(1, 1, 1), 13),
            health = espMakeLabel(bb, 2, Color3.fromRGB(0, 255, 100), 11),
