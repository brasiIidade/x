        Icon = icone,
    })
end

local BaseURL = "https://raw.githubusercontent.com/michigunxyz/michigun/main/"
local FilePaths = {}

local function LoadPathMap()
    local url = BaseURL .. "path.lua?t=" .. tostring(os.time())
    local success, response = pcall(function()
        return game:HttpGet(url)
    end)

    if success then
        local func = loadstring(response)
        if func then
            FilePaths = func()
        end
    end
end

LoadPathMap()

local function ler(key)
    local fileName = FilePaths[key]
    if not fileName then 
        if notificar then
            notificar("Erro:'" .. tostring(key) .. "' não encontrado", 3, "lucide:alert-circle")
        end
        return 
    end

    local url = BaseURL .. fileName .. "?t=" .. tostring(os.time())
    local success, response = pcall(function()
        return game:HttpGet(url)
    end)

    if success then
        local func = loadstring(response)
        if func then
            task.spawn(func)
        end
    else
        if notificar then
            notificar("Erro ao baixar: " .. fileName, 3, "lucide:wifi-off")
        end
    end
end


