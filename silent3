_G.AimbotConfig = _G.AimbotConfig or {
    Enabled = false,
    TeamCheck = "Team",
    TargetPart = {"Random"},
    TargetPriority = "Distance",
    MaxDistance = 1000,
    SwitchThreshold = 1,
    WhitelistedUsers = {},
    WhitelistedTeams = {},
    FocusList = {},
    FocusMode = false,
    UseLegitOffset = true,
    HitChance = 60,
    WallCheck = true,
    FOVSize = 200,
    ShowFOV = true,
    FOVBehavior = "Center",
    FOVNumSides = 20,           
    FOVColor1 = Color3.fromRGB(34, 140, 85),
    FOVColor2 = Color3.fromRGB(250, 255, 252),
    GradientSpeed = 4,
    ShowHighlight = true,
    HighlightColor = Color3.fromRGB(255, 60, 60),
    ESP = {
        Enabled = true, ShowName = true, ShowTeam = true, ShowHealth = true, ShowWeapon = true,
