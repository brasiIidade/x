                            if _pp then _m.insert(_pts,_pp) end
                        end
                    end
                end
            end

            if #_pts==0 then _m.insert(_pts,_rt) end

            for _,pObj in _p(_pts) do
                local _sp,_on=_wts(_cam,pObj.Position)
                if _on then
                    local _dist=(_mouse-Vector2.new(_sp.X,_sp.Y)).Magnitude
                    if _dist<=_fov2 and _visible(pObj,_chr,cfg) then
                        local _isCur=(_state.Target==_chr)
                        local _pd=(pObj.Position-_cPos).Magnitude
                        local _ep2=_isCur and (_pd-5) or _pd
                        if _pri=="Health" then
                            if _hu.Health<_bHP or (_hu.Health==_bHP and _ep2<_bPhy) then
                                _bHP=_hu.Health; _bPhy=_ep2; _bT=_chr; _bP=pObj
                            end
                        else
                            if _ep2<_bPhy then _bPhy=_ep2; _bT=_chr; _bP=pObj end
                        end
                    end
                end
            end
        end
        return _bT,_bP
    end

