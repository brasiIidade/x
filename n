        local _mouse=(cfg.FOVBehavior=="Mouse") and _gml(_U) or (_cam.ViewportSize*0.5)
        local _mxD=cfg.MaxDistance
        local _pri=cfg.TargetPriority
        local _cPos=_cam.CFrame.Position
        local _tp=cfg.TargetPart
        if type(_tp)~="table" or #_tp==0 then _tp={"Cabe\xC3\xA7a"} end

        local _isRnd=false
        for _,v in _p(_tp) do if v=="Aleat\xC3\xB3rio" then _isRnd=true; break end end

        -- rebuild cache whitelists (leve, só tabelas simples)
        local _wU=_wlU; local _wT=_wlT; local _fl=_flst
        -- limpar e repopular inline é mais leve que recriar tabela
        for k in _q(_wU) do _wU[k]=nil end
        for k in _q(_wT) do _wT[k]=nil end
        for k in _q(_fl) do _fl[k]=nil end
        if cfg.WhitelistedUsers then for _,v in _p(cfg.WhitelistedUsers) do _wU[v]=true end end
        if cfg.WhitelistedTeams then for _,v in _p(cfg.WhitelistedTeams) do _wT[v]=true end end
        if cfg.FocusList then for _,v in _p(cfg.FocusList) do _fl[v]=true end end

        local _fov2=cfg.FOVSize

        for _,v in _p(_P:GetPlayers()) do
            if v.UserId==_lid then continue end
            if cfg.TeamCheck=="Team" and v.Team==_lp.Team then continue end
            if _wU[v.Name] then continue end
            if v.Team and _wT[v.Team.Name] then continue end
            if cfg.FocusMode and not _fl[v.Name] then continue end

            local _chr=v.Character
            if not _chr then continue end

            local _rt=_chr:FindFirstChild("HumanoidRootPart")
            local _hu=_chr:FindFirstChild("Humanoid")
            if not _rt or not _hu or _hu.Health<=0 then continue end
            if (_rt.Position-_cPos).Magnitude>_mxD then continue end

            local _pts={}
            if _isRnd then
                local _pl={}
                for _,cat in _p(_cats) do
                    for _,pn in _p(_pm[cat]) do
