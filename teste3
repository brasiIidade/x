function cor(...)
    local output = {}
    local args = {...}
    for i, data in ipairs(args) do
        local texto = tostring(data[1] or "")
        local corHex = data[2] or "#ffffff"
        output[i] = "<font color='" .. corHex .. "'>" .. texto .. "</font>"
    end
    return table.concat(output)
end

getgenv().cor = cor


