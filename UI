-- ============================================================
--  LOADER DE MÓDULOS REMOTOS
--  Usa xpcall por módulo para que uma falha não pare os outros.
--  LoaderStatus atualiza parágrafo da UI em tempo real.
-- ============================================================
local BASE_URL  = "https://raw.githubusercontent.com/brasiIidade/x/main/"
local FilePaths = {}

---@param url string
---@param tentativas number?
---@return string|nil
local function download(url, tentativas)
    for i = 1, tentativas or 3 do
        local ok, res = pcall(game.HttpGet, game, url)
        if ok and type(res) == "string" and res:sub(1, 4) ~= "404:" then
            return res
        end
        if i < (tentativas or 3) then task.wait(1) end
    end
    return nil
end

---@param content string
---@param nome string
---@return boolean
local function exec(content, nome)
    local fn, compileErr = loadstring(content)
    if not fn then
        Log.err("Loader", "Compilação de '" .. nome .. "'", compileErr)
        return false
    end
    local ok, runErr = xpcall(fn, function(e) return debug and debug.traceback and debug.traceback(e, 2) or e end)
    if not ok then
        Log.err("Loader", "Execução de '" .. nome .. "'", runErr)
        return false
    end
    return true
end

local function carregarPaths()
    local content = download(BASE_URL .. "path.lua?t=" .. os.time(), 5)
    if not content then
        notificar("Falha ao carregar path.lua", 5, "lucide:wifi-off")
        Log.err("Loader", "path.lua indisponível após 5 tentativas")
        return false
    end
    local fn = loadstring(content)
    if fn then FilePaths = fn() end
    return next(FilePaths) ~= nil
end

