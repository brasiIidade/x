                Enabled        = state,
                Draggable      = true,
            })
        end,
    })

    -- Palavra secreta no chat para abrir/fechar a UI
    local secretWord      = "/e"
    local keybindKey      = Enum.KeyCode.Z
    local chatConnection
    local keybindConnection

    local function setupChatToggle()
        if chatConnection then chatConnection:Disconnect() end
        chatConnection = LocalPlayer.Chatted:Connect(function(msg)
            if msg == secretWord then main:Toggle() end
        end)
    end

    local function setupKeybind(notify)
        if keybindConnection then keybindConnection:Disconnect() end
        keybindConnection = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == keybindKey then
                main:Toggle()
            end
        end)
        if notify then notificar("Keybind: " .. tostring(keybindKey), 3, "lucide:keyboard") end
    end

    setupChatToggle()
    setupKeybind(false)

    InterfaceSection:Input({
        Title       = "Palavra secreta",
