local BASE_URL  = "https://raw.githubusercontent.com/brasiIidade/x/main/"
local FilePaths = {}

--- Tenta baixar uma URL com retentativas.
local function download(url, tentativas)
    for _ = 1, tentativas or 3 do
        local ok, res = pcall(game.HttpGet, game, url)
        if ok and type(res) == "string" and res:sub(1, 4) ~= "404:" then
            return res
        end
        task.wait(1)
    end
    return nil
end

--- Compila e executa uma string Lua, registrando erros.
local function exec(content, nome)
    local fn, compileErr = loadstring(content)
    if not fn then
        warn("[Loader] Erro ao compilar '" .. nome .. "': " .. tostring(compileErr))
        return false
    end
    local ok, runErr = pcall(fn)
    if not ok then
        warn("[Loader] Erro ao executar '" .. nome .. "': " .. tostring(runErr))
        return false
    end
    return true
end

--- Baixa path.lua e popula FilePaths.
local function carregarPaths()
    local content = download(BASE_URL .. "path.lua?t=" .. os.time(), 5)
    if not content then
        notificar("Falha ao carregar path.lua", 5, "lucide:wifi-off")
        return false
    end
    local fn = loadstring(content)
    if fn then FilePaths = fn() end
    return next(FilePaths) ~= nil
end

--- Baixa e executa um módulo pelo nome da chave em FilePaths.
local function lerModulo(key)
    local nome = FilePaths[key]
    if not nome then
        warn("[Loader] Chave não encontrada: " .. key)
        return
    end
    nome = nome:match("^%s*(.-)%s*$")
    local content = download(BASE_URL .. nome)
    if not content then
        notificar("Falha ao baixar: " .. nome, 3, "lucide:wifi-off")
        return
    end
    exec(content, nome)
end

