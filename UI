local function lerModulo(key)
    LoaderStatus.set(key, "baixando")
    local nome = FilePaths[key]
    if not nome then
        Log.warn("Loader", "Chave não encontrada: " .. key)
        LoaderStatus.set(key, "erro: chave ausente")
        return
    end

    nome = nome:match("^%s*(.-)%s*$")
    local content = download(BASE_URL .. nome)
    if not content then
        notificar("Falha ao baixar: " .. nome, 3, "lucide:wifi-off")
        Log.err("Loader", "Download falhou: " .. nome)
        LoaderStatus.set(key, "erro: download")
        return
    end

    local ok = exec(content, nome)
    LoaderStatus.set(key, ok and "ok" or "erro: execução")
end

if not carregarPaths() then return end

local MODULES = { "combate", "treino", "silent", "player", "jogos" }
for _, nome in ipairs(MODULES) do
    task.spawn(lerModulo, nome)
end

