--// loadstring
local function ler(link)
    local url = "https://raw.githubusercontent.com/brasiIidade/x/main/" .. link
    local success, response = pcall(function()
        return game:HttpGet(url .. "?t=" .. tostring(tick()))
    end)

    if success then
        local func = loadstring(response)
        if func then
            func()
        end
    end
end


